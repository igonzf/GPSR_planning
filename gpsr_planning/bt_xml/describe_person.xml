<?xml version="1.0"?>
<root main_tree_to_execute="DescribePersonTree">
    <!-- ////////// -->
    <BehaviorTree ID="DescribePersonTree">
        <Sequence>
            <Action ID="ChangeLifecycleState" node_name="/llama/llava_node" />

            <RetryUntilSuccessful num_attempts="1000">
                <Sequence>
                    <RetryUntilSuccessful num_attempts="-1">
                        <Sequence>
                            <ReactiveFallback>
                                <Condition ID="IsDetected" 
                                    confidence="0.6" 
                                    interest="person"
                                    max_depth="3.0" 
                                    max_entities="2"
                                    order="depth"
                                    best_detection="{best_detection_global}"/>
                                <Action ID="MoveAlongAxis" 
                                        speed="0.2"
                                        distance="6.28"
                                        axis="z"/>
                            </ReactiveFallback>
                        </Sequence>
                    </RetryUntilSuccessful>
                    <Action ID="CheckPolicy" question="&lt;__media__&gt;
                                                        Start the answer with: 'the person is'.

                                                        Describe the person focusing mainly on their body posture, gestures, and current action.
                                                        Prioritize:
                                                        - body pose (standing, sitting, lying),
                                                        - arm gestures (e.g., pointing left/right, waving, raising an arm),
                                                        - what the person is doing or expressing.

                                                        Also include 1-2 brief physical details (e.g., clothing color or hair), but do NOT focus too much on appearance.

                                                        Use natural language only.
                                                        Do NOT output JSON, lists, or bullet points.
                                                        Return ONE single concise sentence."
                                        output_text="{result_key}"
                                        image_topic="/all_perceptions"/>
                    <Action ID="Speak" say_text="So, " param="{result}"/>
                </Sequence>
            </RetryUntilSuccessful>

            <Action ID="SetBlackboard" output_key="{result_key}" value="{result}" />
            <Action ID="ChangeLifecycleState" node_name="/llama/llava_node" deactivate="true" />
        </Sequence>
    </BehaviorTree>
    <!-- ////////// -->
    <TreeNodesModel>
        <Condition ID="IsDetected">
            <input_port name="cam_frame"/>
            <input_port name="confidence"/>
            <input_port name="person_id"/>
            <input_port name="interest"/>
            <input_port name="max_depth"/>
            <input_port name="max_entities"/>
            <input_port name="order"/>
            <input_port name="best_detection"/>
            <input_port name="frames"/>
        </Condition>
        <Action ID="Speak">
            <input_port name="say_text"/>
            <input_port name="param"/>
        </Action>
        <Action ID="ExtractPersonDescription">
            <input_port default="person" name="person_id"></input_port>
            <input_port name="interest"></input_port>
            <output_port name="description"></output_port>
        </Action>
        <Action ID="CheckPolicy">
            <input_port name="question"/>
            <input_port name="output_text"/>
            <input_port name="image_topic"/>
        </Action>
    </TreeNodesModel>
    <!-- ////////// -->
</root>
