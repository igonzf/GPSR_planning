<?xml version="1.0"?>
<root main_tree_to_execute="FollowPersonTree">
    <!-- ////////// -->
    <BehaviorTree ID="FollowPersonTree">
        <Sequence>
            <Action ID="ChangeLifecycleState" node_name="/perception_people_detection" />
            <Action ID="SwitchYoloModel" model="yolov11n-pose.pt"/>
            <Action ID="Speak" param="" say_text="Now i will follow you. Please stop at the end "/>
            <RetryUntilSuccessful num_attempts="-1">
                <Condition ID="IsDetected" 
                    confidence="0.6" 
                    interest="person"
                    max_depth="3.0" 
                    max_entities="2"
                    order="depth"
                    best_detection="{best_detection_global}"/>
            </RetryUntilSuccessful>
            <Action ID="RemoveStringPrefix" string_to_remove="{best_detection_global}" prefix="person_" result="{id}"/>
            <Action ID="SetPersistentId" id="{id}"/>
            <RetryUntilSuccessful num_attempts="-1">
                <Sequence>
                    <Fallback>
                        <ReactiveSequence>
                            <RetryUntilSuccessful num_attempts="-1">
                                <Condition ID="IsDetected" 
                                                        confidence="0.6" 
                                                        interest="person"
                                                        max_depth="3.0" 
                                                        max_entities="2"
                                                        order="depth"/>
                            </RetryUntilSuccessful>
                            <!-- <Action ID="FilterEntity" frame="{best_detection}" lambda="0.1"/> -->
                            <!-- <Action ID="AddStringSuffix" string_to_modify="{best_detection}" suffix="_filtered" result="{filtered_frame}"/> -->
                            <Action ID="LookAt" tf_frame="{best_detection_global}"/>

                            <Condition ID="IsEntityMoving" distance_tolerance="0.6"
                                                        robot_distance_to_person="1.5"
                                                        frame="{best_detection_global}"
                                                        check_time="8.0"/>
                            <Action ID="FollowEntity" camera_frame="head_front_camera_optical_frame"
                                                    distance_tolerance="0.2"
                                                    frame_to_follow="{best_detection_global}"
                                                    x_axis_max="20.0"
                                                    x_axis_min="-20.0"
                                                    y_axis_max="20.0"
                                                    y_axis_min="-20.0"/>
                        </ReactiveSequence>
                        <Action ID="Speak" param="" say_text="have we arrived to the destination?"/>
                    </Fallback>
                    <ReactiveSequence>
                        <RetryUntilSuccessful num_attempts="-1">
                            <Condition ID="IsDetected" confidence="0.3" 
                                                        interest="person" 
                                                        max_depth="2.5" 
                                                        max_entities="1" 
                                                        order="color"/>
                        </RetryUntilSuccessful>
                        <!-- <Action ID="FilterEntity" frame="{best_detection}" lambda="0.1"/> -->
                        <!-- <Action ID="AddStringSuffix" string_to_modify="{best_detection}" suffix="_filtered" result="{best_detection}"/> -->
                        <Action ID="LookAt" tf_frame="{best_detection_global}"/>
                        <ForceSuccess>
                            <Action ID="GoalPublisher" 
                            camera_frame="head_front_camera_optical_frame"
                            distance_tolerance="0.2"
                            frame_to_follow="{best_detection_global}"/>  
                        </ForceSuccess>
                        <Action ID="DialogConfirmation"/>
                    </ReactiveSequence>
                </Sequence>
            </RetryUntilSuccessful>
            <Action ID="ChangeLifecycleState" node_name="/perception_people_detection" deactivate="true"/>
        </Sequence>
    </BehaviorTree>
    <!-- ////////// -->
    <TreeNodesModel>
        <Condition ID="IsEntityMoving">
            <input_port name="distance_tolerance"/>
            <input_port name="frame"/>
            <input_port name="check_time"/>
        </Condition>
        <Condition ID="IsDetected">
            <input_port name="cam_frame"/>
            <input_port name="confidence"/>
            <input_port name="person_id"/>
            <input_port name="interest"/>
            <input_port name="max_depth"/>
            <input_port name="max_entities"/>
            <input_port name="order"/>
            <input_port name="best_detection"/>
            <input_port name="frames"/>
        </Condition>
        <Action ID="FollowEntity">
            <input_port name="camera_frame"/>
            <input_port name="distance_tolerance"/>
            <input_port name="frame_to_follow"/>
            <input_port name="x_axis_max"/>
            <input_port name="x_axis_min"/>
            <input_port name="y_axis_max"/>
            <input_port name="y_axis_min"/>
        </Action>
        <Action ID="FilterEntity">
            <input_port name="frame"/>
            <input_port name="lambda"/>
        </Action>
        <Action ID="GoalPublisher">
            <input_port name="camera_frame"/>
            <input_port name="distance_tolerance"/>
            <input_port name="frame_to_follow"/>
        </Action>
        <Action ID="DialogConfirmation">
        </Action>
        <Action ID="LookAt">
            <input_port name="tf_frame"/>
        </Action>
        <Action ID="Speak">
            <input_port name="say_text"/>
            <input_port name="param"/>
        </Action>
    </TreeNodesModel>
    <!-- ////////// -->
</root>