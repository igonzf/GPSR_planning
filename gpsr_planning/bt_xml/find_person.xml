<?xml version="1.0"?>
<root main_tree_to_execute="FindPersonTree">
    <!-- ////////// -->
    <BehaviorTree ID="FindPersonTree">
        <Sequence>
            <Action ID="SwitchYoloModel" model="yolov8n-pose"/>
            <Action ID="SetHeadJointPosition" vertical="-0.15"/>
            <Action ID="SetTorsoHeight" height="0.1"/>

            <RetryUntilSuccessful num_attempts="86"> <!-- 43 attempts at 0.15 rad == 1 turn -->
                <Sequence>
                    <ReactiveFallback>
                        <!-- <Condition ID="IsGesturing" type="{gesture}" person_id="{person_id}"/> -->
                        <Condition ID="IsDetected" color="{color}" gesture="{arm_gesture}" pose="{body_position}" confidence="0.3" person_id="{person_id}" interest="person" max_depth="2.5" max_entities="1" order="color"/>
                        <Action ID="MoveAlongAxis" 
                        speed="0.5"
                        distance="6.28"
                        axis="z"/>
                    </ReactiveFallback>
                <!-- TODO Si se hace el MoveTo, añadir el FilterEntity-->
                <Action ID="Speak" say_text="I found you." param=""/>
                </Sequence>
            </RetryUntilSuccessful>
            <Action ID="SetHeadJointPosition" vertical="0.0"/>
            <Action ID="SetTorsoHeight" height="0.15"/>
                <Fallback>
                    <BlackboardCheckString value_A="{search_by}" value_B="name" return_on_mismatch="FAILURE">
                        <Action ID="AlwaysSuccess"/>
                    </BlackboardCheckString>
                    <RetryUntilSuccessful num_attempts="10000">
                        <Sequence>
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames=""
                                        max_depth="3" max_entities="1" order="depth_nearest" />
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05" />
                                <Action ID="Speak" say_text="What's your name?" />
                            </ReactiveSequence>
                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames=""
                                        max_depth="3" max_entities="1" order="depth_nearest" />
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05" />
                            </ReactiveSequence>

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames=""
                                        max_depth="3" max_entities="1" order="depth_nearest" />
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05" />
                                <Action ID="Listen" listen_text="{text_value}" />
                            </ReactiveSequence>

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames=""
                                        max_depth="3" max_entities="1" order="depth_nearest" />
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05" />
                                <Action ID="Query" text="{text_value}" intention="name"
                                    intention_value="{result}" />
                            </ReactiveSequence>

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames=""
                                        max_depth="3" max_entities="1" order="depth_nearest" />
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05" />
                                <Action ID="Speak" say_text="So you are" param="{result}" />
                                <Action ID="Speak" say_text="Please say yes or no" />
                            </ReactiveSequence>

                            <ReactiveSequence>
                                <RetryUntilSuccessful num_attempts="-1">
                                    <Condition ID="IsDetected" confidence="0.6" interest="person" frames="" max_depth="3" max_entities="1" order="depth_nearest"/>
                                </RetryUntilSuccessful>
                                <Action ID="FilterEntity" frame="person_0" lambda="0.05"/>
                                <Action ID="DialogConfirmation" />
                            </ReactiveSequence>
                            <Action ID="SetBlackboard" output_key="{result_key}" value="{result}"/>
                        </Sequence>
                    </RetryUntilSuccessful>
                </Fallback>
        </Sequence>
    </BehaviorTree>
    <!-- ////////// -->
    <TreeNodesModel>
        <Condition ID="IsGesturing">
            <input_port name="type"/>
            <input_port name="person_id"/>
        </Condition>
        <Condition ID="IsDetected">
            <input_port name="cam_frame"/>
            <input_port name="confidence"/>
            <input_port name="person_id"/>
            <input_port name="interest"/>
            <input_port name="max_depth"/>
            <input_port name="max_entities"/>
            <input_port name="order"/>
            <input_port name="best_detection"/>
            <input_port name="frames"/>
        </Condition>
        <Action ID="SetPerceptionModel">
            <input_port name="model_name"/>
        </Action>
        <Action ID="ConvertColor">
            <input_port name="interest"/>
            <input_port name="color"/>
            <input_port name="person_id"/>
        </Action>
        <Action ID="Pan">
            <input_port name="period"/>
            <input_port name="range"/>
            <input_port name="pitch_angle"/>
        </Action>
        <Action ID="MoveTo">
            <input_port default="0" name="distance_tolerance"/>
            <input_port default="entrance" name="tf_frame"/>
            <input_port default="true" name="will_finish"/>
            <input_port default="true" name="is_truncated"/>
        </Action>
        <Action ID="Speak">
            <input_port name="say_text"/>
            <input_port name="param"/>
        </Action>
        <Action ID="SetHeadJointPosition">
            <input_port name="vertical"/>
        </Action>
        <Action ID="SetTorsoHeight">
            <input_port name="height"/>
        </Action>

    </TreeNodesModel>
    <!-- ////////// -->
</root>
